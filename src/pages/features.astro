---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FeaturesComponent from "../components/Features.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Ce que nous faisons | Protech`}
  description="Découvrez les activités de Protech : ateliers, projets, compétitions et communauté pour étudiant·e·s passionné·e·s par la programmation et la technologie."
  canonicalURL={`${SITE.url}/features`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-6xl mx-auto px-4 py-20">

      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold text-gray-900 mb-4">
          Ce que nous faisons
        </h1>
      </ScrollReveal>

      <ScrollReveal client:load delay={0.1}>
        <p class="text-xl text-gray-600 mb-12">
          Protech est un club étudiant qui propose des ateliers, des projets,
          des compétitions et une communauté inclusive pour apprendre, créer
          et expérimenter en programmation et technologie.
        </p>
      </ScrollReveal>

      <FeaturesComponent />

    </section>
  </main>
  <Footer />
</Layout>
