---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FeaturesComponent from "../components/Features.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Ce que nous faisons | Protech`}
  description="Découvrez les activités de Protech : ateliers, projets, compétitions et communauté pour étudiant·e·s passionné·e·s par la programmation et la technologie."
  canonicalURL={`${SITE.url}/features`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-6xl mx-auto px-4 pt-16 pb-4">

      <ScrollReveal client:idle>
        <p class="text-shell-muted text-sm mb-2">
          <span class="text-shell-green">visitor@protech</span>:<span class="text-shell-blue">~</span>$ protech --list
        </p>
        <h1 class="text-3xl font-bold text-shell-text mb-4">
          <span class="text-shell-green">#</span> Ce que nous faisons
        </h1>
      </ScrollReveal>

      <ScrollReveal client:load delay={0.1}>
        <p class="text-shell-muted mb-4 max-w-2xl leading-relaxed">
          Protech propose des ateliers, des projets, des compétitions et une communauté inclusive
          pour apprendre, créer et expérimenter en programmation et technologie.
        </p>
      </ScrollReveal>

    </section>

    <FeaturesComponent />

  </main>
  <Footer />
</Layout>
