---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Contact | Protech`}
  description="Contactez-nous ! Nous serions ravi·es d’échanger avec vous sur Protech, nos ateliers, compétitions ou tout autre question."
  canonicalURL={`${SITE.url}/contact`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-2xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold text-gray-900 mb-4">Contact</h1>
      </ScrollReveal>

      <ScrollReveal client:idle delay={0.2}>
        <p class="text-xl text-gray-600 mb-6">
          Vous pouvez nous contacter par le formulaire ci-dessous, par email ou rejoindre directement notre serveur Discord.
        </p>
      </ScrollReveal>

      <ScrollReveal client:idle delay={0.3}>
        <div class="mb-12 flex flex-col sm:flex-row gap-4">
          <a
            href="http://discord.gg/gSq43BvhYg"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 px-6 py-4 bg-indigo-600 text-white rounded-lg font-medium text-center hover:bg-indigo-700 transition-colors"
          >
            Rejoindre notre Discord
          </a>
          <a
            href="mailto:contact@protech.sh"
            class="flex-1 px-6 py-4 border border-gray-300 rounded-lg text-gray-900 font-medium text-center hover:bg-gray-100 transition-colors"
          >
            Envoyer un email
          </a>
        </div>
      </ScrollReveal>

      <ScrollReveal client:idle delay={0.4}>
        <ContactForm />
      </ScrollReveal>
    </section>
  </main>
  <Footer />
</Layout>
