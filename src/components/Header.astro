---
import Logo from "../assets/logo.svg";
---

<header
	class="w-full py-3 px-4 border-b border-shell-border bg-shell-surface sticky top-0 z-50"
	role="banner"
>
	<nav
		class="max-w-6xl mx-auto flex items-center justify-between"
		aria-label="Navigation principale"
	>
		<!-- ~/protech logo -->
		<a
			href="/"
			class="flex items-center gap-1.5 text-shell-text hover:text-shell-green transition-colors group"
			aria-label="Protech - Accueil"
		>
			<Logo width="26" height="26" />
			<span class="text-shell-muted text-sm">~/</span>
			<span class="text-sm font-medium">protech</span>
			<span class="text-shell-green text-sm cursor-blink">▌</span>
		</a>

		<!-- Mobile menu button -->
		<button
			type="button"
			class="md:hidden p-2 text-shell-muted hover:text-shell-text focus:outline-none focus:ring-1 focus:ring-shell-green transition-colors"
			aria-label="Basculer le menu"
			aria-expanded="false"
			aria-controls="mobile-menu"
			id="mobile-menu-button"
		>
			<svg
				class="w-5 h-5"
				fill="none"
				stroke="currentColor"
				viewBox="0 0 24 24"
				aria-hidden="true"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="1.5"
					d="M4 6h16M4 12h16M4 18h16"></path>
			</svg>
		</button>

		<!-- Desktop nav -->
		<ul class="hidden md:flex items-center gap-0" role="list">
			<li>
				<a
					href="/features"
					class="px-4 py-2 text-sm text-shell-muted hover:text-shell-green hover:bg-shell-bg transition-colors"
					aria-current={Astro.url.pathname === "/features" ? "page" : undefined}
				>
					<span class="text-shell-green text-xs">~/</span>features
				</a>
			</li>
			<li>
				<a
					href="/about"
					class="px-4 py-2 text-sm text-shell-muted hover:text-shell-green hover:bg-shell-bg transition-colors"
					aria-current={Astro.url.pathname === "/about" ? "page" : undefined}
				>
					<span class="text-shell-green text-xs">~/</span>about
				</a>
			</li>
			<li class="ml-4">
				<a
					href="https://discord.gg/gSq43BvhYg"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 px-4 py-2 text-sm bg-shell-green text-shell-bg hover:bg-shell-green-bright transition-colors font-medium"
					aria-label="Rejoindre notre serveur Discord"
				>
					<svg
						class="w-4 h-4"
						fill="currentColor"
						viewBox="0 0 24 24"
						aria-hidden="true"
					>
						<path
							d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.003.02.014.04.03.052a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.995a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"
						></path>
					</svg>
					$ join
				</a>
			</li>
		</ul>
	</nav>

	<!-- Mobile menu -->
	<div
		id="mobile-menu"
		class="hidden md:hidden border-t border-shell-border bg-shell-bg"
		role="menu"
		aria-labelledby="mobile-menu-button"
	>
		<ul class="flex flex-col py-2" role="list">
			<li>
				<a
					href="/features"
					class="flex items-center gap-2 px-4 py-3 text-sm text-shell-muted hover:text-shell-green hover:bg-shell-surface transition-colors"
					role="menuitem"
					aria-current={Astro.url.pathname === "/features" ? "page" : undefined}
				>
					<span class="text-shell-green">$</span> features
				</a>
			</li>
			<li>
				<a
					href="/about"
					class="flex items-center gap-2 px-4 py-3 text-sm text-shell-muted hover:text-shell-green hover:bg-shell-surface transition-colors"
					role="menuitem"
					aria-current={Astro.url.pathname === "/about" ? "page" : undefined}
				>
					<span class="text-shell-green">$</span> about
				</a>
			</li>
			<li>
				<a
					href="https://discord.gg/gSq43BvhYg"
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-center gap-2 px-4 py-3 text-sm text-shell-green hover:bg-shell-surface transition-colors"
					role="menuitem"
					aria-label="Rejoindre notre serveur Discord (nouvel onglet)"
				>
					$ join --discord
				</a>
			</li>
		</ul>
	</div>
</header>

<script>
	const menuButton = document.getElementById("mobile-menu-button");
	const mobileMenu = document.getElementById("mobile-menu");

	if (menuButton && mobileMenu) {
		menuButton.addEventListener("click", () => {
			const isExpanded = menuButton.getAttribute("aria-expanded") === "true";
			menuButton.setAttribute("aria-expanded", String(!isExpanded));
			mobileMenu.classList.toggle("hidden");
		});

		document.addEventListener("click", (e) => {
			if (
				!menuButton.contains(e.target as Node) &&
				!mobileMenu.contains(e.target as Node) &&
				!mobileMenu.classList.contains("hidden")
			) {
				menuButton.setAttribute("aria-expanded", "false");
				mobileMenu.classList.add("hidden");
			}
		});

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && !mobileMenu.classList.contains("hidden")) {
				menuButton.setAttribute("aria-expanded", "false");
				mobileMenu.classList.add("hidden");
				menuButton.focus();
			}
		});
	}
</script>
