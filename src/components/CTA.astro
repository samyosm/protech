---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
---

<section id="about" class="max-w-6xl mx-auto px-4 py-20">
  <ScrollReveal client:idle scale={true}>
    <div class="bg-black rounded-2xl p-12 text-center text-white">
      <h2 class="text-4xl font-bold mb-4">Prêt·e à rejoindre Protech ?</h2>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Rejoins une communauté d’étudiants passionnés par la programmation et la technologie.
				Projets, ateliers et entraide. Tout commence ici!
      </p>
      <a
        href="http://discord.gg/gSq43BvhYg"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3 bg-white text-black rounded-lg hover:bg-gray-100 transition-colors font-medium"
        aria-label="Rejoins nous sur Discord (ouvre sur Discord)"
      >
				<Icon name="tabler:brand-discord-filled" class="w-5 h-5" aria-hidden="true" />
        <span>Nous rejoindre</span>
      </a>
    </div>
  </ScrollReveal>
</section>
