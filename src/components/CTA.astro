---
import ScrollReveal from "./ScrollReveal.tsx";
---

<section id="about" class="max-w-6xl mx-auto px-4 py-20">
	<ScrollReveal client:idle scale={true}>
		<div class="border border-shell-green/30 bg-shell-surface relative overflow-hidden">
			<!-- Top border accent -->
			<div class="h-px w-full bg-gradient-to-r from-transparent via-shell-green to-transparent"></div>

			<div class="p-10 md:p-14 text-center">
				<p class="text-shell-muted text-sm mb-4">
					<span class="text-shell-green">visitor@protech</span>:<span class="text-shell-blue">~</span>$ ./join.sh
				</p>
				<h2 class="text-2xl md:text-3xl font-bold text-shell-text mb-4">
					Prêt·e à rejoindre Protech ?
				</h2>
				<p class="text-shell-muted text-base mb-8 max-w-xl mx-auto leading-relaxed">
					Rejoins une communauté d'étudiants passionnés par la programmation et la technologie.
					Projets, ateliers et entraide. Tout commence ici.
				</p>
				<a
					href="http://discord.gg/gSq43BvhYg"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 px-7 py-3 bg-shell-green text-shell-bg hover:bg-shell-green-bright transition-colors font-medium text-sm"
					aria-label="Rejoins nous sur Discord"
				>
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.003.02.014.04.03.052a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.995a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
					</svg>
					<span class="opacity-60 mr-0.5">$</span> Nous rejoindre
				</a>
			</div>

			<!-- Bottom border accent -->
			<div class="h-px w-full bg-gradient-to-r from-transparent via-shell-green to-transparent"></div>
		</div>
	</ScrollReveal>
</section>
