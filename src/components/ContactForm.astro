---
import { SITE } from "../config/site.mjs";

const web3formsAccessKey = SITE.web3formsAccessKey || "";
---

<form
	id="contact-form"
	class="space-y-5"
	aria-label="Formulaire de contact"
	novalidate
	action="https://api.web3forms.com/submit"
	method="POST"
>
	{web3formsAccessKey && (
		<input type="hidden" name="access_key" value={web3formsAccessKey} />
	)}
	<input type="hidden" name="subject" value="Nouvelle soumission de formulaire de contact" />
	<input type="hidden" name="redirect" value="false" />
	<input type="checkbox" name="botcheck" class="hidden" style="display: none;" tabindex="-1" autocomplete="off" />

	<!-- Success -->
	<div
		id="success-message"
		class="hidden p-4 bg-shell-surface border border-shell-green/50 text-shell-green text-sm"
		role="alert"
		aria-live="polite"
	>
		<p class="font-medium"><span class="opacity-60">$</span> Merci pour votre message !</p>
		<p class="text-shell-muted mt-1">Nous vous répondrons dès que possible.</p>
	</div>

	<!-- Error -->
	<div
		id="error-message"
		class="hidden p-4 bg-shell-surface border border-shell-red/50 text-shell-red text-sm"
		role="alert"
		aria-live="assertive"
	>
		<p class="font-medium" id="error-text"></p>
	</div>

	<!-- Nom -->
	<div>
		<label for="name" class="block text-xs text-shell-muted mb-2 uppercase tracking-widest">
			<span class="text-shell-green">$</span> from_name
			<span class="text-shell-red ml-1" aria-label="obligatoire">*</span>
		</label>
		<input
			type="text"
			id="name"
			name="from_name"
			class="w-full px-4 py-3 bg-shell-surface border border-shell-border text-shell-text placeholder:text-shell-muted/50 focus:border-shell-green focus:outline-none transition-colors text-sm"
			required
			aria-required="true"
			aria-describedby="name-error"
			placeholder="Votre nom"
			autocomplete="name"
		/>
		<span
			id="name-error"
			class="mt-1.5 text-xs text-shell-red hidden"
			role="alert"
			aria-live="polite"
		></span>
	</div>

	<!-- Email -->
	<div>
		<label for="email" class="block text-xs text-shell-muted mb-2 uppercase tracking-widest">
			<span class="text-shell-green">$</span> from_email
			<span class="text-shell-red ml-1" aria-label="obligatoire">*</span>
		</label>
		<input
			type="email"
			id="email"
			name="from_email"
			class="w-full px-4 py-3 bg-shell-surface border border-shell-border text-shell-text placeholder:text-shell-muted/50 focus:border-shell-green focus:outline-none transition-colors text-sm"
			required
			aria-required="true"
			aria-describedby="email-error"
			placeholder="exemple@domaine.com"
			autocomplete="email"
		/>
		<span
			id="email-error"
			class="mt-1.5 text-xs text-shell-red hidden"
			role="alert"
			aria-live="polite"
		></span>
	</div>

	<!-- Message -->
	<div>
		<label for="message" class="block text-xs text-shell-muted mb-2 uppercase tracking-widest">
			<span class="text-shell-green">$</span> message
			<span class="text-shell-red ml-1" aria-label="obligatoire">*</span>
		</label>
		<textarea
			id="message"
			name="message"
			rows="6"
			class="w-full px-4 py-3 bg-shell-surface border border-shell-border text-shell-text placeholder:text-shell-muted/50 focus:border-shell-green focus:outline-none transition-colors resize-none text-sm"
			required
			aria-required="true"
			aria-describedby="message-error"
			placeholder="Écrivez votre message ici..."></textarea>
		<span
			id="message-error"
			class="mt-1.5 text-xs text-shell-red hidden"
			role="alert"
			aria-live="polite"
		></span>
	</div>

	<!-- Submit -->
	<button
		type="submit"
		id="submit-button"
		class="w-full px-6 py-3 bg-shell-green text-shell-bg hover:bg-shell-green-bright transition-colors font-medium text-sm focus:outline-none focus:ring-1 focus:ring-shell-green focus:ring-offset-1 focus:ring-offset-shell-bg disabled:opacity-40 disabled:cursor-not-allowed"
	>
		<span id="submit-text"><span class="opacity-60 mr-1">$</span> Envoyer le message</span>
		<span id="submit-loading" class="hidden">Envoi en cours...</span>
	</button>
</form>

<script>
	const form = document.getElementById("contact-form") as HTMLFormElement;
	const submitButton = document.getElementById("submit-button") as HTMLButtonElement;
	const submitText = document.getElementById("submit-text")!;
	const submitLoading = document.getElementById("submit-loading")!;
	const successMessage = document.getElementById("success-message")!;
	const errorMessage = document.getElementById("error-message")!;
	const errorText = document.getElementById("error-text")!;

	const nameInput = document.getElementById("name") as HTMLInputElement;
	const emailInput = document.getElementById("email") as HTMLInputElement;
	const messageInput = document.getElementById("message") as HTMLTextAreaElement;
	const nameError = document.getElementById("name-error")!;
	const emailError = document.getElementById("email-error")!;
	const messageError = document.getElementById("message-error")!;

	function validateEmail(email: string) {
		return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
	}

	function showFieldError(field: HTMLElement, errorEl: HTMLElement, msg: string) {
		field.setAttribute("aria-invalid", "true");
		field.classList.add("border-shell-red");
		field.classList.remove("border-shell-border");
		errorEl.textContent = msg;
		errorEl.classList.remove("hidden");
	}

	function clearFieldError(field: HTMLElement, errorEl: HTMLElement) {
		field.setAttribute("aria-invalid", "false");
		field.classList.remove("border-shell-red");
		field.classList.add("border-shell-border");
		errorEl.classList.add("hidden");
		errorEl.textContent = "";
	}

	function setLoading(loading: boolean) {
		submitButton.disabled = loading;
		submitText.classList.toggle("hidden", loading);
		submitLoading.classList.toggle("hidden", !loading);
	}

	nameInput.addEventListener("blur", () => {
		const v = nameInput.value.trim();
		if (!v) showFieldError(nameInput, nameError, "Le nom est obligatoire");
		else if (v.length < 2) showFieldError(nameInput, nameError, "Au moins 2 caractères");
		else clearFieldError(nameInput, nameError);
	});

	emailInput.addEventListener("blur", () => {
		const v = emailInput.value.trim();
		if (!v) showFieldError(emailInput, emailError, "L'email est obligatoire");
		else if (!validateEmail(v)) showFieldError(emailInput, emailError, "Email invalide");
		else clearFieldError(emailInput, emailError);
	});

	messageInput.addEventListener("blur", () => {
		const v = messageInput.value.trim();
		if (!v) showFieldError(messageInput, messageError, "Le message est obligatoire");
		else if (v.length < 10) showFieldError(messageInput, messageError, "Au moins 10 caractères");
		else clearFieldError(messageInput, messageError);
	});

	const accessKeyInput = form.querySelector('input[name="access_key"]') as HTMLInputElement | null;
	const hasAccessKey = !!accessKeyInput?.value.trim();

	form.addEventListener("submit", async (e) => {
		e.preventDefault();
		successMessage.classList.add("hidden");
		errorMessage.classList.add("hidden");

		if (!hasAccessKey) {
			errorText.textContent = "Le formulaire n'est pas configuré.";
			errorMessage.classList.remove("hidden");
			return;
		}

		clearFieldError(nameInput, nameError);
		clearFieldError(emailInput, emailError);
		clearFieldError(messageInput, messageError);

		let valid = true;
		if (!nameInput.value.trim()) { showFieldError(nameInput, nameError, "Le nom est obligatoire"); valid = false; }
		if (!emailInput.value.trim()) { showFieldError(emailInput, emailError, "L'email est obligatoire"); valid = false; }
		else if (!validateEmail(emailInput.value.trim())) { showFieldError(emailInput, emailError, "Email invalide"); valid = false; }
		if (!messageInput.value.trim()) { showFieldError(messageInput, messageError, "Le message est obligatoire"); valid = false; }
		else if (messageInput.value.trim().length < 10) { showFieldError(messageInput, messageError, "Au moins 10 caractères"); valid = false; }

		if (!valid) {
			const first = form.querySelector('[aria-invalid="true"]') as HTMLElement | null;
			first?.focus();
			return;
		}

		setLoading(true);
		try {
			const res = await fetch("https://api.web3forms.com/submit", { method: "POST", body: new FormData(form) });
			const data = await res.json();
			if (res.ok && data.success) {
				successMessage.classList.remove("hidden");
				form.reset();
				successMessage.scrollIntoView({ behavior: "smooth", block: "nearest" });
			} else {
				errorText.textContent = data.message || "Échec de l'envoi. Veuillez réessayer.";
				errorMessage.classList.remove("hidden");
			}
		} catch {
			errorText.textContent = "Erreur réseau. Vérifiez votre connexion.";
			errorMessage.classList.remove("hidden");
		} finally {
			setLoading(false);
		}
	});
</script>
